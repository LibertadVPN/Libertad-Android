<shortcuts xmlns:android="http://schemas.android.com/apk/res/android">
    <shortcut
        android:shortcutId="toggle_vpn"
        android:enabled="true"
        android:icon="@android:drawable/ic_lock_lock"
        android:shortcutShortLabel="@string/app_shortcut_label"
        android:shortcutLongLabel="@string/app_shortcut_label">

        <intent
            android:action="android.intent.action.VIEW"
            android:targetPackage="org.libertad.vpn"
            android:targetClass="org.libertad.vpn.appShortcuts.AppShortcut"
            android:data="vpn://toggle"/>
    </shortcut>
</shortcuts>